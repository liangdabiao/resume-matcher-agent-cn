# ============================================================
# 后端环境变量。使用前复制为 .env：
#   cp .env.sample .env
# ============================================================

# 运行环境：local / production。
# production 下会强制校验下面的 Key/密钥。
ENV="local"

# 【必填】OpenAI 兼容 API Key。production 下为空会拒绝启动。
LLM_API_KEY=""

# OpenAI 兼容 API Base URL 和模型名。默认智谱 glm-5.1，可换成 DeepSeek、腾讯 TokenHub 等。
LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"
LL_MODEL="glm-5.1"

# Session 签名密钥。production 下不能是默认值 change-me。
# 生成随机字符串：python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY="change-me"

# 后端监听端口（本地 run.py 默认读这个；宝塔用 gunicorn 时在面板里设端口）。
BACKEND_PORT=8000

# ---- 以下保持默认即可，无需修改 ----

# 日志目录。默认 apps/backend/logs。
# LOG_DIR="/www/wwwroot/resume-matcher/apps/backend/logs"

# CORS 来源（逗号分隔）。同源反代部署（宝塔/nginx 同域名）留空即可。
# 仅当前端用独立域名/端口访问后端才需要填：
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
