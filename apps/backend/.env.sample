# ============================================================
# 后端环境变量示例。使用前复制为 .env：
#   cp apps/backend/.env.sample apps/backend/.env
# ============================================================

# Session 签名密钥。
# 本地开发可用默认值；ENV=production 时【必须】改成随机字符串，否则后端拒绝启动。
# 生成随机字符串示例：python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY="change-me"

# 数据库地址（SQLite，本地相对路径）。Docker 部署时由 compose 覆盖为 /app/data/app.db。
SYNC_DATABASE_URL="sqlite:///./app.db"
ASYNC_DATABASE_URL="sqlite+aiosqlite:///./app.db"

PYTHONDONTWRITEBYTECODE=1

# 运行环境：local / staging / production。
# production 下会强制校验 LLM_API_KEY 与 SESSION_SECRET_KEY。
ENV="local"

# CORS 允许的来源（逗号分隔，或 JSON 数组字符串）。
# - 同源反代部署（宝塔/nginx 同域名访问）：留空或不设置，无需 CORS。
# - 前端用独立域名/端口访问后端：填前端实际访问地址，例如：
#     ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
# 不设置时默认放行本地开发端口（localhost/127.0.0.1:3000-3002）。
# ALLOWED_ORIGINS=""

# 日志目录。本地开发可不设（默认 apps/backend/logs）。
# 宝塔/服务器部署建议设为绝对路径，避免进程工作目录不确定导致日志散落：
#   LOG_DIR="/www/wwwroot/resume-matcher/apps/backend/logs"
# LOG_DIR=""

# ------------------------------------------------------------
# LLM 配置（核心）。下面三项决定了简历分析能否正常工作。
# ------------------------------------------------------------

# 【必填】OpenAI 兼容 API Key。ENV=production 时为空会拒绝启动。
LLM_API_KEY=""

# OpenAI 兼容 API Base URL。默认智谱；可换成 DeepSeek、腾讯 TokenHub 等。
LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# 模型名称，需与 LLM_BASE_URL 对应的供应商支持的模型一致。
LL_MODEL="glm-5.1"
