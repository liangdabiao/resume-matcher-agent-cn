# ============================================================
# 前端环境变量示例。使用前复制为 .env：
#   cp apps/frontend/.env.sample apps/frontend/.env
# ============================================================

# 浏览器请求后端 API 的基础地址。取值规则：
#
#   1) 本地开发（前端直连后端，浏览器跨域到 8000 端口）—— 填完整地址：
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000"
#
#   2) Docker / nginx 同源反代部署 —— 必须设为空字符串，前端请求相对路径 /api/...，
#      由 Next.js rewrites 或 nginx 转发到后端：
# NEXT_PUBLIC_API_URL=""
#
#   3) 服务器内网 IP 直连（无反代，浏览器与后端跨主机）—— 填浏览器能访问到的地址：
# NEXT_PUBLIC_API_URL="http://192.168.x.x:8000"
#
# 注意：设为空字符串 "" 时（区别于不设置），前端走相对路径，配合 rewrites 同源访问；
# 完全不设置（删除该变量）时才回退到 http://127.0.0.1:8000。
