{
    "name": "resume-matcher",
    "version": "0.0.1",
    "description": "Veridis Quo.",
    "private": true,
    "scripts": {
        "install:frontend": "cd apps/frontend && npm install",
        "install:backend": "cd apps/backend && pip install -r requirements.txt",
        "setup": "npm install && npm run install:frontend && npm run install:backend",
        "dev:backend": "cd apps/backend && python app.py",
        "dev:frontend": "cd apps/frontend && npm run dev",
        "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
        "build:frontend": "cd apps/frontend && npm run build",
        "build:backend": "cd apps/backend && python -m compileall app.py config.py llm.py parser.py prompts.py run.py store.py",
        "build": "npm run build:frontend && npm run build:backend",
        "start:backend": "cd apps/backend && gunicorn -w 2 -b 0.0.0.0:8000 --timeout 300 app:app",
        "start:frontend": "cd apps/frontend && npm start",
        "start": "concurrently \"npm:start:backend\" \"npm:start:frontend\"",
        "docker:build": "docker compose build",
        "docker:up": "docker compose up",
        "docker:down": "docker compose down",
        "lint:frontend": "cd apps/frontend && npm run lint",
        "lint": "npm run lint:frontend",
        "test:e2e": "cd apps/backend && python test_e2e.py",
        "test:e2e:fast": "cd apps/backend && python test_e2e.py --skip-llm"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    }
}